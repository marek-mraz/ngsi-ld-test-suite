{
   "id":"urn:ngsi-ld:Subscription:randomUUID",
   "type":"Subscription",
   "entities":[
      {
         "type":"https://ngsi-ld-test-suite/context#Vehicle"
      }
   ],
   "timeInterval": 5,
   "notification":{
      "format":"keyValues",
      "endpoint":{
         "uri":"http://localhost:1111/notify",
         "accept":"application/json"
      }
   },
   "status": "active",
   "notificationTrigger": [
      "attributeCreated",
      "attributeUpdated"
   ],
   "@context":[
      "https://forge.etsi.org/rep/cim/ngsi-ld-test-suite/-/raw/develop/resources/jsonld-contexts/ngsi-ld-test-suite-compound.jsonld"
   ]
}